  "entities": [
    {
      "id": "spawn_note",
      "type": "note",
      "x": 27.5,
      "y": 37.5,
      "title": "Записка на полу",
      "text": "Дата неразборчива.\nПрепарат принят. Сон без сновидений.\nДверь палаты должна быть закрыта снаружи —\nно я слышу шаги.\n\nЕсли это я завтрашний —\nне открывай.",
      "isDocument": true
    },
    {
      "id": "cell_b_graffiti",
      "type": "note",
      "x": 5.5,
      "y": 38.5,
      "title": "Надпись на стене у койки",
      "text": "Кто-то прорезал в краске:\n\nя НЕ пациент №14.\nя пациент №14 был раньше.\nя пациент №14 БУДЕТ.",
      "isDocument": false
    },

    {
      "id": "archive_note",
      "type": "note",
      "x": 10.5,
      "y": 5.5,
      "title": "Журнал санитарного поста — обрывок",
      "text": "...пациент №14 повторно жалуется на\nголоса из вентиляции.\nНазначен галоперидол 5мг внутримышечно.\n\nПометка карандашом снизу:\n\"перестал жаловаться.\nперестал говорить.\nперестал моргать.\"",
      "isDocument": true
    },
    {
      "id": "archive_note_2",
      "type": "note",
      "x": 18.5,
      "y": 8.5,
      "title": "Карточка пациента",
      "text": "Пациент №14.\nПоступил без сопровождения.\nДокументы не сохранились.\nРодственники не установлены.\n\nВ нижней графе чужой почерк:\n\"и не будут.\"",
      "isDocument": true
    },

    {
      "id": "procedure_note",
      "type": "note",
      "x": 10.5,
      "y": 13.5,
      "title": "Карта процедур",
      "text": "Электросудорожная терапия —\nежедневно, без расписания.\nПротоколы не сохраняются.\n\nВнизу другим почерком:\n\"они не лечат.\nони подключают.\"",
      "isDocument": true
    },

    {
      "id": "ward_a_note",
      "type": "note",
      "x": 18.5,
      "y": 24.5,
      "title": "Дневник пациента (помят)",
      "text": "Я вижу его снова.\nОн всегда у вентиляции.\nКогда я моргаю —\nон уже на два шага ближе.",
      "isDocument": false
    },

    {
      "id": "storage_note",
      "type": "note",
      "x": 45.5,
      "y": 31.5,
      "title": "Опись имущества",
      "text": "К списку приклеена записка:\n\n\"если ключ пропал —\nне ищи.\nон уже у того, кто должен.\"",
      "isDocument": true
    },

