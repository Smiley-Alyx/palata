  "messagePools": {
    "note": [
      {
        "title": "Записка на полу",
        "text": "Дата неразборчива.\nЗабрали кофту, заколки и зеркало.\nСказали: \"здесь тебя отучат быть таким\".\n\nПрепарат принят. Сон без сновидений.\nЕсли утром я отвечу на номер 14 —\nнапомни мне моё имя.",
        "isDocument": true
      },
      {
        "title": "Опись имущества",
        "text": "Ведомость изъятого имущества.\nПациент №14: блуза, лента для волос,\nкосметичка, письмо без адреса.\n\nЗачёркнуто: \"вернуть при выписке\".\nДопись санитара:\n\"тряпки этой принцессе не понадобятся\".",
        "isDocument": true
      },
      {
        "title": "Журнал санитарного поста — обрывок",
        "text": "...пациент №14 доставлен за демонстративно\nженственный облик и отказ \"исправиться\".\nНазначен галоперидол 5 мг внутримышечно.\n\nПометка карандашом:\n\"в юбке плакал громче.\nбез неё всё равно выглядит девчонкой\".",
        "isDocument": true
      },
      {
        "title": "Карточка пациента",
        "text": "Пациент №14.\nПоступил без сопровождения.\nДокументы не сохранились.\nРодственники не установлены.\n\nВ нижней графе чужой почерк:\n\"и не будут.\"",
        "isDocument": true
      },
      {
        "title": "Лист назначений",
        "text": "Пациент №14.\nПосле вечернего обхода просит вернуть зеркало.\nНазначение: изоляция, седативные, тишина.\n\nВнизу приписано:\n\"ключ оставлять там, где он его увидит\".",
        "isDocument": true
      },
      {
        "title": "Запись дежурного",
        "text": "Ключ снова оказался в палате №14.\nПациент утверждает, что дверь открылась сама.\n\nКрасным карандашом:\n\"не спорить с ним после отбоя.\nкоридор слушает\".",
        "isDocument": true
      }
    ],
    "inscription": [
      {
        "title": "Надпись у койки",
        "text": "Краска содрана ногтями:\n\n\"КУКОЛКА, НА ОБХОД!\"\n\nНиже, тонкой царапиной:\nя не их шутка.\nя не их диагноз.",
        "isDocument": false
      },
      {
        "title": "Плитка в душевой",
        "text": "На мокрой плитке выцарапано:\n\n\"СМОЙ С ЛИЦА ДЕВЧОНКУ\".\n\nПоверх чужих букв:\nя смывал до крови.\nэто было не на лице.",
        "isDocument": false
      }
    ],
    "card": [
      {
        "title": "Карточка пациента",
        "text": "Пациент №14.\nОснование госпитализации:\n\"социальная девиация\" — женственная\nвнешность, одежда и манеры.\n\nДиагноз: нестабильное поведение.\nЗачёркнуто: \"опасен\".\nВписано: \"удобен для наблюдения\".",
        "isDocument": true
      },
      {
        "title": "Карта процедур",
        "text": "Корректирующие процедуры:\nгалоперидол; изоляция; ЭСТ.\nЦель: подавление \"женственной фиксации\".\n\nКрасными чернилами:\n\"после сеанса назвал себя мальчиком\".\nКарандашом рядом:\n\"соврал, чтобы прекратили\".",
        "isDocument": true
      }
    ]
  },
