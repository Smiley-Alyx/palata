// Sidebar with status / controls / audio / system panels.

.sidebar
  border-left 4px solid $wood-dark
  background linear-gradient(180deg, #2a1a11 0%, #1a1210 100%)
  padding 12px
  display flex
  flex-direction column
  gap 12px
  grid-row 1 / 2

.panel
  border 2px solid $wood
  background rgba(0, 0, 0, 0.35)
  padding 10px

  hr
    border none
    border-top 1px solid rgba(243, 210, 122, 0.25)
    margin 8px 0

.panel-title
  font-size 14px
  letter-spacing 1px
  text-transform uppercase
  margin 0 0 10px
  color $accent

.help-list
  list-style none
  padding 0
  margin 0
  display flex
  flex-direction column
  gap 8px
  font-size 12px
  line-height 1.3

.key
  display inline-block
  padding 2px 6px
  border 1px solid rgba(243, 210, 122, 0.55)
  background rgba(0, 0, 0, 0.35)
  color $accent

.hint
  font-size 11px
  color rgba(216, 216, 216, 0.75)
  line-height 1.3
