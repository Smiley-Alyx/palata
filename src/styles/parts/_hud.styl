// HUD bar at the bottom of the viewport.

.hud
  grid-column 1 / -1
  display grid
  grid-template-columns 1fr 1fr 1fr 1fr 1fr
  align-items center
  gap 12px
  padding 10px 12px
  border-top 4px solid $wood-dark
  background linear-gradient(180deg, #2c2c2c 0%, #151515 100%)

  :fullscreen &
    border-top 0

.hud-block
  height 92px
  border 2px solid #1f1f1f
  background rgba(0, 0, 0, 0.35)
  display grid
  grid-template-rows 1fr auto
  align-items center
  justify-items center
  padding 6px 8px
  width 100%
  box-sizing border-box

.hud-value
  font-size 34px
  line-height 1
  font-weight 700
  letter-spacing 1px
  color $danger
  text-shadow 0 2px 0 rgba(0, 0, 0, 0.65)

.hud-label
  font-size 12px
  letter-spacing 2px
  color rgba(255, 255, 255, 0.75)

.hud-keys-row
  display flex
  gap 8px
  align-items center
  justify-content center

.hud-key
  width 28px
  height 28px
  image-rendering pixelated
  filter grayscale(1) brightness(0.65)
  opacity 0.65

  &.is-owned
    filter none
    opacity 1

.hud-face
  height 92px
  border 2px solid #1f1f1f
  background rgba(0, 0, 0, 0.45)
  display flex
  align-items center
  justify-content center
  width 100%
  box-sizing border-box
  padding 0
  overflow hidden

  canvas
    height 100%
    width auto
    image-rendering pixelated

.hud-weapon
  justify-items start
  padding 10px 12px
  grid-template-rows 1fr
  align-items start
  justify-content start

.hud-weapon-title
  font-size 12px
  letter-spacing 2px
  color rgba(255, 255, 255, 0.75)

.hud-weapon-value
  font-size 18px
  color $text

.hud-weapon-row
  width 100%
  display flex
  align-items baseline
  justify-content space-between
  gap 10px

  & + &
    margin-top 6px
