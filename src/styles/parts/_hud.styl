// HUD bar at the bottom of the viewport.

.hud
  grid-column 1 / -1
  display grid
  grid-template-columns minmax(70px, 0.7fr) minmax(64px, 0.6fr) minmax(110px, 1fr) 132px minmax(64px, 0.6fr) minmax(64px, 0.6fr) minmax(96px, 0.9fr)
  align-items center
  gap 8px
  padding 8px 10px
  border-top 4px solid $wood-dark
  background linear-gradient(180deg, #2c2c2c 0%, #151515 100%)

  :fullscreen &
    border-top 0

.hud-block
  height 78px
  border 2px solid #1f1f1f
  background rgba(0, 0, 0, 0.35)
  display grid
  grid-template-rows 1fr auto
  align-items center
  justify-items center
  padding 5px 6px
  width 100%
  box-sizing border-box
  min-width 0

.hud-value
  font-size 26px
  line-height 1
  font-weight 700
  letter-spacing 0
  color $danger
  text-shadow 0 2px 0 rgba(0, 0, 0, 0.65)
  max-width 100%
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.hud-label
  font-size 10px
  letter-spacing 1px
  color rgba(255, 255, 255, 0.75)

.hud-keys-row
  display flex
  gap 6px
  align-items center
  justify-content center
  min-height 42px

.hud-key
  display none
  height 42px
  background-repeat no-repeat
  image-rendering pixelated

  &.is-owned
    display block

.hud-key-gold
  width 15.55px
  background-image url('/assets/sprites/pickups/keys/gold_key_hd.png')
  background-size 81.77px 54.54px
  background-position -8.73px -3.78px

.hud-key-silver
  width 15.99px
  background-image url('/assets/sprites/pickups/keys/silver_key_hd.png')
  background-size 89.00px 59.32px
  background-position -9.50px -5.56px

.hud-key-blood
  width 17.59px
  background-image url('/assets/sprites/pickups/keys/blood_key.png')
  background-size 75.92px 50.60px
  background-position -3.46px -1.98px

.hud-face
  height 78px
  border 2px solid #1f1f1f
  background rgba(0, 0, 0, 0.45)
  display flex
  align-items center
  justify-content center
  width 100%
  box-sizing border-box
  padding 0
  overflow hidden

  canvas
    height 100%
    width auto
    image-rendering pixelated

.hud-weapon
  .hud-value
    color $text
    font-size 18px
