// Wolf3D-style loading splash + flicker animations.

.loading
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  background #000
  z-index 30
  font-family $mono
  color $text

.loading-box
  width min(480px, 92%)
  text-align center
  padding 24px 18px
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 0 64px rgba(0, 0, 0, 0.8)
  background linear-gradient(180deg, #1a0d08 0%, #0a0605 100%)

.loading-brand
  color $accent
  font-size 36px
  letter-spacing 8px
  text-transform uppercase
  margin-bottom 14px
  animation loading-flicker 2.4s infinite steps(1)

.loading-title
  color rgba(236, 236, 236, 0.92)
  font-size 14px
  letter-spacing 2px
  text-transform uppercase
  margin-bottom 6px

.loading-subtitle
  color rgba(216, 216, 216, 0.6)
  font-size 12px
  letter-spacing 1px
  margin-bottom 18px

.loading-bar
  width 100%
  height 14px
  border 2px solid $wood
  background #0a0605
  margin 0 auto 14px
  overflow hidden

.loading-bar-fill
  width 0%
  height 100%
  background linear-gradient(90deg, $danger 0%, $accent 100%)
  transition width 80ms linear

.loading-hint
  color rgba(243, 210, 122, 0.7)
  font-size 11px
  letter-spacing 3px
  text-transform uppercase
  animation loading-blink 1s infinite steps(2)

@keyframes loading-flicker
  0%, 92%, 100%
    opacity 1
  93%
    opacity 0.4
  94%
    opacity 1
  96%
    opacity 0.2
  97%
    opacity 1

@keyframes loading-blink
  0%
    opacity 0.35
  100%
    opacity 1
