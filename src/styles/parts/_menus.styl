// Modal-style overlays: main menu, death screen, note.

.menu
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  background radial-gradient(circle at center, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.85) 70%)
  z-index 10

.menu-box
  width min(420px, 90%)
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.6)
  background linear-gradient(180deg, #24160f 0%, #140f0d 100%)
  padding 18px
  text-align center

.menu-title
  color $accent
  font-size 28px
  letter-spacing 2px
  text-transform uppercase
  margin-bottom 6px

.menu-subtitle
  color rgba(216, 216, 216, 0.85)
  font-size 12px
  margin-bottom 16px

.menu-buttons
  display flex
  flex-direction column
  gap 10px

.note
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  background radial-gradient(circle at center, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.75) 70%)
  z-index 10

.note-box
  width min(560px, 92%)
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.6)
  background linear-gradient(180deg, #24160f 0%, #140f0d 100%)
  padding 18px

.note-title
  color $accent
  font-size 18px
  letter-spacing 1px
  text-transform uppercase
  margin-bottom 10px

.note-text
  color rgba(236, 236, 236, 0.9)
  font-size 13px
  line-height 1.45
  white-space pre-wrap
  margin-bottom 12px

.note-hint
  color rgba(216, 216, 216, 0.65)
  font-size 11px
  text-align right
