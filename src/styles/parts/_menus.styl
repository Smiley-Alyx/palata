// Modal-style overlays: main menu, death screen, note.

.menu
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  background radial-gradient(circle at center, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.85) 70%)
  z-index 10

.menu-box
  width min(460px, 90%)
  max-height 92%
  overflow auto
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.6)
  background linear-gradient(180deg, #2a2117 0%, #120d0b 100%)
  padding 18px
  text-align center

.menu-title
  color $accent
  font-size 38px
  letter-spacing 3px
  text-transform uppercase
  margin-bottom 6px
  text-shadow 3px 3px 0 #000

.menu-subtitle
  color rgba(216, 216, 216, 0.85)
  font-size 12px
  margin-bottom 16px

.menu--death
  background radial-gradient(circle at center, rgba(60, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.92) 70%)

.menu--death .menu-title
  color $danger
  font-size 36px
  letter-spacing 6px
  text-shadow 0 0 16px rgba(209, 29, 29, 0.45)

.menu-epitaph
  color rgba(236, 236, 236, 0.78)
  font-size 13px
  line-height 1.5
  font-style italic
  white-space pre-wrap
  margin 4px 0 14px
  min-height 1.5em

.menu-buttons
  display flex
  flex-direction column
  gap 10px

.menu-panel
  display flex
  flex-direction column
  gap 12px

.menu-section-title
  color $accent
  font-size 14px
  letter-spacing 2px
  text-transform uppercase
  text-align left
  border-bottom 1px solid rgba(243, 210, 122, 0.35)
  padding-bottom 6px

.menu-panel .help-list
  text-align left
  max-height 230px
  overflow auto

.control-bind-row
  display grid
  grid-template-columns minmax(0, 1fr) minmax(118px, 38%)
  align-items center
  gap 8px
  margin-bottom 6px

.control-bind-action
  color rgba(236, 236, 236, 0.86)
  font-size 12px
  line-height 1.25

.control-bind-btn
  min-height 30px
  padding 5px 6px
  font-size 11px
  letter-spacing 0

.credits-list
  list-style none
  padding 0
  margin 0
  display flex
  flex-direction column
  gap 8px
  color rgba(236, 236, 236, 0.82)
  font-size 12px
  line-height 1.4
  text-align left

.menu--ending
  background radial-gradient(circle at center, rgba(20, 10, 30, 0.7) 0%, rgba(0, 0, 0, 0.95) 70%)
  animation ending-fade 1.6s ease-in 0s 1 both

.menu--ending .menu-box
  border-color #5b3a76
  box-shadow 0 0 0 4px #2a1638, 0 16px 48px rgba(0, 0, 0, 0.75)

.menu--ending .menu-title
  color #d8c7ff
  font-size 32px
  letter-spacing 4px
  text-shadow 0 0 18px rgba(170, 120, 220, 0.45)

.menu--ending .menu-epitaph
  color rgba(220, 200, 240, 0.85)
  font-size 14px

.menu--ending .menu-subtitle
  color rgba(200, 180, 220, 0.65)
  font-style italic

.menu--level-transition
  background radial-gradient(circle at center, rgba(30, 18, 6, 0.62) 0%, rgba(0, 0, 0, 0.92) 70%)
  z-index 20
  animation ending-fade 0.8s ease-in 0s 1 both

.menu--level-transition .menu-title
  color $accent
  font-size 30px
  letter-spacing 4px

.menu--level-transition .menu-epitaph
  color rgba(236, 236, 236, 0.82)

@keyframes ending-fade
  from
    opacity 0
    filter brightness(0)
  to
    opacity 1
    filter brightness(1)

.note
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  background radial-gradient(circle at center, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.75) 70%)
  z-index 10

.note-box
  width min(560px, 92%)
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.6)
  background linear-gradient(180deg, #24160f 0%, #140f0d 100%)
  padding 18px

.note-title
  color $accent
  font-size 18px
  letter-spacing 1px
  text-transform uppercase
  margin-bottom 10px

.note-text
  color rgba(236, 236, 236, 0.9)
  font-size 13px
  line-height 1.45
  white-space pre-wrap
  margin-bottom 12px

.note-hint
  color rgba(216, 216, 216, 0.65)
  font-size 11px
  text-align right
