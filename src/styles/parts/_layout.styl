// Top-level layout: app shell, frame grid, viewport.

html, body
  height 100%

body
  margin 0
  background $bg-deep
  color $text
  font-family $mono

.app
  height 100vh
  box-sizing border-box
  display flex
  align-items center
  justify-content center
  padding 24px

.frame
  width unquote('min(100%, 1200px, calc((100vh - 160px) * 4 / 3))')
  display grid
  grid-template-columns 1fr
  grid-template-rows auto
  gap 0
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.55)
  background $bg-frame

.frame.has-hud
  grid-template-rows auto 112px

.app:fullscreen
  padding 0

.frame:fullscreen
  width 100vw
  height 100vh
  grid-template-columns minmax(0, 1fr) unquote('min(100vw, calc(100vh * 4 / 3))') minmax(0, 1fr)
  grid-template-rows unquote('min(100vh, calc(100vw * 3 / 4))')
  align-content center
  justify-content stretch
  border 0
  box-shadow none
  background $bg-frame

.frame.has-hud:fullscreen
  grid-template-columns minmax(0, 1fr) unquote('min(100vw, calc((100vh - 112px) * 4 / 3))') minmax(0, 1fr)
  grid-template-rows unquote('min(calc(100vh - 112px), calc(100vw * 3 / 4))') 112px

:fullscreen .app
  padding 0

:fullscreen .frame
  width 100vw
  height 100vh
  grid-template-columns minmax(0, 1fr) unquote('min(100vw, calc(100vh * 4 / 3))') minmax(0, 1fr)
  grid-template-rows unquote('min(100vh, calc(100vw * 3 / 4))')
  align-content center
  justify-content stretch

:fullscreen .frame.has-hud
  grid-template-columns minmax(0, 1fr) unquote('min(100vw, calc((100vh - 112px) * 4 / 3))') minmax(0, 1fr)
  grid-template-rows unquote('min(calc(100vh - 112px), calc(100vw * 3 / 4))') 112px

.viewport
  position relative
  min-width 0
  min-height 0
  aspect-ratio 4 / 3
  background #000
  overflow hidden
  grid-row 1 / 2

  :fullscreen &
    grid-column 2 / 3
    width 100%
    height 100%
    aspect-ratio auto

  canvas
    display block
    width 100%
    height 100%

.fps-counter
  position absolute
  left 10px
  top 8px
  z-index 8
  color #fff
  font-size 13px
  line-height 1
  font-weight 700
  text-shadow 1px 1px 0 #000, -1px 1px 0 #000, 1px -1px 0 #000, -1px -1px 0 #000
  pointer-events none

@media (max-width: 900px)
  .frame
    grid-template-columns 1fr
    grid-template-rows 1fr

  .frame.has-hud
    grid-template-rows 1fr 112px
