// Top-level layout: app shell, frame grid, viewport.

html, body
  height 100%

body
  margin 0
  background $bg-deep
  color $text
  font-family $mono

.app
  height 100vh
  box-sizing border-box
  display flex
  align-items center
  justify-content center
  padding 24px

.frame
  width min(1200px, 100%)
  height min(720px, 100%)
  display grid
  grid-template-columns 1fr 280px
  grid-template-rows 1fr 112px
  gap 0
  border 4px solid $wood
  box-shadow 0 0 0 4px $wood-dark, 0 16px 48px rgba(0, 0, 0, 0.55)
  background $bg-frame

:fullscreen .app
  padding 0

:fullscreen .frame
  width 100vw
  height 100vh
  border none
  box-shadow none
  grid-template-columns 1fr
  grid-template-rows 1fr 112px

:fullscreen .sidebar
  display none

.viewport
  position relative
  min-width 0
  min-height 0
  background #000
  overflow hidden
  grid-row 1 / 2

  canvas
    display block

@media (max-width: 900px)
  .frame
    grid-template-columns 1fr
    grid-template-rows 1fr 112px
    height auto
  .sidebar
    border-left none
    border-top 4px solid $wood-dark
