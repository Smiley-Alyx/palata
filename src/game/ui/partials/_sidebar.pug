//- Sidebar with status, controls, audio and system panels.

aside.sidebar
  section.panel
    h2.panel-title Status
    .hint#fpsText FPS: 0

  section.panel
    h2.panel-title Controls
    ul.help-list
      li
        span.key W/A/S/D
        |  / 
        span.key Arrows
        |  — движение
      li
        span.key Shift
        |  — спринт
      li
        span.key E
        |  — открыть дверь
      li
        span.key Space
        |  — выстрел / удар
      li
        span.key 1/2/3
        |  — труба / пистолет / дробовик
      li
        span.key Q
        |  — циклически переключать оружие
      li
        span.key V
        |  — рывок (predator)
      li
        span.key M
        |  — карта
      li
        span.key F
        |  — fullscreen

  section.panel
    h2.panel-title Audio
    .control-group
      button.btn#musicToggleBtn(type="button") Music: on
      label.label
        | Music volume
        input.range#musicVolume(type="range" min="0" max="1" step="0.01" value="0.5")
      button.btn#sfxToggleBtn(type="button") SFX: on
      label.label
        | SFX volume
        input.range#sfxVolume(type="range" min="0" max="1" step="0.01" value="0.7")
      .hint Первый клик по окну игры включает звук (ограничения браузера).

  section.panel
    h2.panel-title System
    .control-group
      button.btn#fullscreenBtn(type="button") Fullscreen
