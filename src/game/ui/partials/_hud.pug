//- Bottom HUD: stats, portrait, weapon, keys.

.hud#hudRoot
  .hud-block.hud-stat
    .hud-value#hudHealthValue 100%
    .hud-label HEALTH
  .hud-block.hud-stat
    .hud-value#hudArmorValue 0%
    .hud-label ARMOR
  .hud-block.hud-weapon
    .hud-value#hudWeaponValue -
    .hud-label WEAPON
  .hud-face
    canvas#hudPortrait(width="128" height="96")
  .hud-block.hud-stat
    .hud-value#hudAmmoValue 50
    .hud-label AMMO
  .hud-block.hud-stat
    .hud-value#hudMedsValue 0
    .hud-label MEDS
  .hud-keys.hud-block
    .hud-keys-row
      .hud-key.hud-key-gold#hudKeyGold
      .hud-key.hud-key-silver#hudKeySilver
      .hud-key.hud-key-blood#hudKeyBlood
    .hud-label KEYS
