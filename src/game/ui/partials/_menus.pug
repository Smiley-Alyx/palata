//- Main menu, death modal and note overlay.

.menu#menuRoot
  .menu-box
    .menu-title PALATA
    .menu-subtitle Soviet psychiatric horror

    .menu-panel#menuMainPanel
      .menu-buttons
        button.btn#menuNewGameBtn(type="button") New Game
        button.btn#menuSavesBtn(type="button") Saves
        button.btn#menuSettingsBtn(type="button") Settings
        button.btn#menuCreditsBtn(type="button") Credits

    .menu-panel#menuPausePanel(style="display: none")
      .menu-section-title Paused
      .menu-buttons
        button.btn#menuResumeBtn(type="button") Resume
        button.btn#menuPauseSettingsBtn(type="button") Settings
        button.btn#menuPauseMainBtn(type="button") Main Menu

    .menu-panel#menuNewGamePanel(style="display: none")
      .menu-section-title Choose difficulty
      #menuDifficulty.menu-buttons
      .menu-buttons
        button.btn#menuStartBtn(type="button") Start
        button.btn.menu-back(type="button" data-menu-target="menuMainPanel") Back

    .menu-panel#menuSavesPanel(style="display: none")
      .menu-section-title Saves
      .menu-epitaph Save slots are sealed for now.
      .menu-buttons
        button.btn.menu-back(type="button" data-menu-target="menuMainPanel") Back

    .menu-panel#menuSettingsPanel(style="display: none")
      .menu-section-title Settings
      .control-group
        button.btn#musicToggleBtn(type="button") Music: on
        label.label
          | Music volume
          input.range#musicVolume(type="range" min="0" max="1" step="0.01" value="0.5")
        button.btn#sfxToggleBtn(type="button") SFX: on
        label.label
          | SFX volume
          input.range#sfxVolume(type="range" min="0" max="1" step="0.01" value="0.7")
        button.btn#fpsToggleBtn(type="button") FPS: on
        button.btn#fullscreenBtn(type="button") Fullscreen
      .menu-section-title Controls
      ul.help-list#menuControls
      button.btn#controlsResetBtn(type="button") Reset controls
      .menu-buttons
        button.btn.menu-back(type="button" data-menu-target="contextRoot") Back

    .menu-panel#menuCreditsPanel(style="display: none")
      .menu-section-title Credits
      ul.credits-list#menuCredits
      .menu-buttons
        button.btn.menu-back(type="button" data-menu-target="menuMainPanel") Back

.menu.menu--death#deathRoot(style="display: none")
  .menu-box
    .menu-title#deathTitle You Die
    .menu-epitaph#deathEpitaph
    .menu-subtitle The ward keeps its patients
    .menu-buttons
      button.btn#deathRestartBtn(type="button") Restart

.menu.menu--ending#endingRoot(style="display: none")
  .menu-box
    .menu-title#endingTitle
    .menu-epitaph#endingBody
    .menu-subtitle#endingSubtitle
    .menu-buttons
      button.btn#endingContinueBtn(type="button") Return to the ward

.menu.menu--level-transition#levelTransitionRoot(style="display: none")
  .menu-box
    .menu-title Door opened
    .menu-epitaph#levelTransitionBody
    .menu-subtitle Entering the next ward

.note#noteRoot(style="display: none")
  .note-box
    .note-title#noteTitle
    .note-text#noteText
    .note-hint Press E or Esc to close
