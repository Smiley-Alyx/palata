//- Main menu, death modal and note overlay.

.menu#menuRoot
  .menu-box
    .menu-title PALATA
    .menu-subtitle Soviet psychiatric horror
    .menu-buttons
      #menuDifficulty
      #menuLevels

.menu.menu--death#deathRoot(style="display: none")
  .menu-box
    .menu-title#deathTitle You Die
    .menu-epitaph#deathEpitaph
    .menu-subtitle The ward keeps its patients
    .menu-buttons
      button.btn#deathRestartBtn(type="button") Restart

.menu.menu--ending#endingRoot(style="display: none")
  .menu-box
    .menu-title#endingTitle
    .menu-epitaph#endingBody
    .menu-subtitle#endingSubtitle
    .menu-buttons
      button.btn#endingContinueBtn(type="button") Return to the ward

.menu.menu--level-transition#levelTransitionRoot(style="display: none")
  .menu-box
    .menu-title Door opened
    .menu-epitaph#levelTransitionBody
    .menu-subtitle Entering the next ward

.note#noteRoot(style="display: none")
  .note-box
    .note-title#noteTitle
    .note-text#noteText
    .note-hint Press E or Esc to close
